# ===========================================
# AB Insurance CRM - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Supabase Configuration (Required)
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...YOUR_ANON_KEY
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT-ID

# ===========================================
# Edge Function Secrets (Set via Supabase CLI)
# ===========================================
# These are set using: supabase secrets set KEY=value

# Bunny CDN Configuration
# BUNNY_API_KEY=your-bunny-api-key
# BUNNY_STORAGE_ZONE=your-storage-zone-name
# BUNNY_CDN_URL=https://your-cdn.b-cdn.net

# Supabase Service Role (for Edge Functions)
# SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
